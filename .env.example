# Copy this file to .env and fill in your values.
# app.py / utils/*.py load these via os.getenv() (and python-dotenv if you add
# `from dotenv import load_dotenv; load_dotenv()` at the top of app.py).

# ---- Cricbuzz API (RapidAPI) ----
# Get a free key at https://rapidapi.com/hub -> search "Cricbuzz Cricket"
CRICBUZZ_API_KEY=your_rapidapi_key_here

# ---- Database selection ----
# sqlite (default, zero setup) | postgresql | mysql
DB_TYPE=sqlite

# Only needed if DB_TYPE=sqlite and you want a custom path
SQLITE_PATH=data/cricbuzz_livestats.db

# ---- PostgreSQL (only needed if DB_TYPE=postgresql) ----
PG_HOST=localhost
PG_PORT=5432
PG_DB=cricbuzz_livestats
PG_USER=postgres
PG_PASSWORD=

# ---- MySQL (only needed if DB_TYPE=mysql) ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=cricbuzz_livestats
MYSQL_USER=root
MYSQL_PASSWORD=
